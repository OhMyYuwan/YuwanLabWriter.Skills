{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yuwanlab.local/schemas/marketplace.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "skills"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "generated_at": {
      "type": "string"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "display_name",
          "version",
          "author_github",
          "description",
          "tags",
          "license",
          "path",
          "entry",
          "skill_url",
          "entry_url",
          "checksum_sha256",
          "repo_url",
          "source_url",
          "source_ref",
          "skill_name",
          "install_command"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "author_github": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "license": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "entry": {
            "type": "string"
          },
          "skill_url": {
            "type": "string"
          },
          "entry_url": {
            "type": "string"
          },
          "readme_url": {
            "type": "string"
          },
          "checksum_sha256": {
            "type": "string"
          },
          "repo_url": {
            "type": "string"
          },
          "source_url": {
            "type": "string"
          },
          "source_ref": {
            "type": "string"
          },
          "skill_name": {
            "type": "string"
          },
          "install_command": {
            "type": "string"
          },
          "source_type": {
            "type": "string",
            "enum": [
              "local",
              "external"
            ]
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
